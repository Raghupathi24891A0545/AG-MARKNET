# =================================================================
# AGRI-CONNECT — Environment Variables (.env.example)
# Copy this file to .env and fill in your real keys
# =================================================================

# ---------------------------------------------------------------
# CORE FLASK
# ---------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-me-to-something-long-and-random

# ---------------------------------------------------------------
# POSTGRESQL DATABASE
# Create a DB: createdb agriconnect
# ---------------------------------------------------------------
DATABASE_URL=postgresql://postgres:1234@localhost:5432/agriconnect

# ---------------------------------------------------------------
# OPENWEATHERMAP (One Call 3.0 or 2.5 free tier)
# Sign up: https://openweathermap.org/api
# ---------------------------------------------------------------
OPENWEATHERMAP_API_KEY=your_api_key_here

# ---------------------------------------------------------------
# SOILGRIDS / ISRIC (Free – no key needed, but rate-limited)
# Uses: https://rest.isric.org/soilgrids/v2.0/
# SOILHIVE (optional premium): https://soilhive.ag
# ---------------------------------------------------------------
SOILHIVE_API_KEY=

# ---------------------------------------------------------------
# GOOGLE EARTH ENGINE (optional satellite)
# Register: https://earthengine.google.com/
# Place your service account JSON as ee_credentials.json in backend/
# ---------------------------------------------------------------
EE_SERVICE_ACCOUNT=
EE_PRIVATE_KEY_FILE=ee_credentials.json

# ---------------------------------------------------------------
# AGRICULTURE NEWS (optional – NewsAPI)
# Sign up: https://newsapi.org/
# ---------------------------------------------------------------
NEWSAPI_KEY=

# ---------------------------------------------------------------
# GEMINI / OPENAI for chatbot (optional)
# ---------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------
# CORS / FRONTEND
# ---------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
